# Server Configuration
NODE_ENV=development
HOST=0.0.0.0
PORT=3001

# MongoDB Configuration
MONGO_URI=mongodb://127.0.0.1:27017/
MONGO_DATABASE=content-reviewer-backend

# AWS Configuration
AWS_REGION=eu-west-2
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Upload Configuration
UPLOAD_S3_BUCKET=dev-service-optimisation-c63f2
UPLOAD_S3_PATH=content-uploads
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_MIME_TYPES=["application/pdf","application/msword","application/vnd.openxmlformats-officedocument.wordprocessingml.document"]

# S3 Event Trigger Mode
# Set to 'true' to use S3 automatic event notifications (recommended for production)
# Set to 'false' to use manual SQS calls from upload route (useful for testing)
# When enabled, S3 will automatically trigger SQS when files are uploaded
S3_EVENT_TRIGGER_ENABLED=false

# SQS Configuration
SQS_QUEUE_URL=http://localhost:4566/000000000000/content_review_status
SQS_QUEUE_NAME=content_review_status
SQS_REGION=eu-west-2

# CORS Configuration
CORS_ORIGIN=["http://localhost:3000"]
CORS_CREDENTIALS=true

# Logging
LOG_ENABLED=true
LOG_LEVEL=info
LOG_FORMAT=pino-pretty
