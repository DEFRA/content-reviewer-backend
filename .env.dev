# ==================================================
# CDP DEV ENVIRONMENT CONFIGURATION
# ==================================================
NODE_ENV=production
ENVIRONMENT=dev
PORT=3001

# ==================================================
# AWS CONFIGURATION (Real AWS - No LocalStack)
# ==================================================
# AWS credentials are provided via IAM role in CDP
# Do NOT set AWS_ENDPOINT for real AWS
AWS_REGION=eu-west-2

# ==================================================
# S3 CONFIGURATION
# ==================================================
UPLOAD_S3_BUCKET=dev-service-optimisation-c63f2
UPLOAD_S3_PATH=content-uploads
UPLOAD_MAX_FILE_SIZE=10485760

# S3 Event Trigger Configuration
# Set to true to use automatic S3 event notifications (recommended)
# S3 will automatically send events to SQS when files are uploaded
# Set to false to use manual SQS calls from upload route (legacy mode)
S3_EVENT_TRIGGER_ENABLED=true

# ==================================================
# SQS CONFIGURATION
# ==================================================
SQS_QUEUE_URL=https://sqs.eu-west-2.amazonaws.com/332499610595/content_review_status
SQS_QUEUE_NAME=content_review_status
SQS_REGION=eu-west-2

# ==================================================
# CORS CONFIGURATION
# ==================================================
CORS_ORIGIN=["https://content-reviewer-frontend.dev.cdp-int.defra.cloud"]
CORS_CREDENTIALS=true

# ==================================================
# LOGGING
# ==================================================
LOG_LEVEL=info
LOG_FORMAT=ecs
LOG_ENABLED=true

# ==================================================
# METRICS
# ==================================================
ENABLE_METRICS=true

# ==================================================
# MONGO (if needed)
# ==================================================
MONGO_ENABLED=false
